{
  "entities": {
    "TeacherProfile": {
      "title": "Teacher Profile",
      "description": "Extended teacher record with performance and profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "principal"] },
        "currentScore": { "type": "number", "description": "Running performance score for the current month" },
        "yearlyKpi": { "type": "number", "description": "Final yearly KPI score (0-100)" },
        "completionProgress": { "type": "number" }
      },
      "required": ["id", "fullName", "email", "role"]
    },
    "PerformanceLog": {
      "title": "Performance Log",
      "description": "Individual score adjustments made by principal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "principalId": { "type": "string" },
        "amount": { "type": "number", "description": "Positive or negative mark change" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "category": { "type": "string", "enum": ["Teaching", "Attendance", "Discipline", "Extra-Curricular", "Professionalism"] }
      },
      "required": ["id", "teacherId", "amount", "reason", "timestamp", "category"]
    },
    "MonthlySummary": {
      "title": "Monthly Summary",
      "description": "Aggregated stats for a teacher for a specific month",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "month": { "type": "string", "description": "YYYY-MM format" },
        "totalScore": { "type": "number" },
        "status": { "type": "string", "enum": ["Excellent", "Good", "Satisfactory", "Needs Improvement"] },
        "reportUrl": { "type": "string", "description": "URL to generated PDF report" }
      },
      "required": ["id", "teacherId", "month", "totalScore"]
    },
    "Warning": {
      "title": "Warning",
      "description": "Formal warnings issued to teachers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "issuedBy": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["Verbal", "Written", "Final"] }
      },
      "required": ["id", "teacherId", "message", "severity"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notifications for users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["performance", "admin", "leave", "duty_swap"] }
      },
      "required": ["id", "userId", "title", "message", "read", "timestamp"]
    },
    "DutyTask": {
      "title": "Duty Task",
      "description": "Template for a recurring duty",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "timeStart": { "type": "string" },
        "timeEnd": { "type": "string" },
        "frequency": { "type": "string", "enum": ["Daily", "Weekly", "Monthly"] },
        "locations": { "type": "array", "items": { "type": "string" } },
        "minPeople": { "type": "number" },
        "checklistTemplates": { "type": "array", "items": { "type": "string" } },
        "genderRequirement": { "type": "string", "enum": ["Female", "Male", "Other"] }
      },
      "required": ["id", "name", "timeStart", "timeEnd", "frequency"]
    },
    "DutyLocation": {
      "title": "Duty Location",
      "description": "Location where duties are performed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "DutyAssignment": {
      "title": "Duty Assignment",
      "description": "Instance of a duty assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "taskName": { "type": "string" },
        "date": { "type": "string" },
        "locationId": { "type": "string" },
        "locationName": { "type": "string" },
        "teacherIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "checklist": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "taskId", "date", "locationId", "teacherIds", "status"]
    },
    "LeaveRecord": {
      "title": "Leave Record",
      "description": "Teacher leave applications",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "type": { "type": "string" }
      },
      "required": ["id", "teacherId", "startDate", "endDate", "status"]
    },
    "DutySwapRequest": {
      "title": "Duty Swap Request",
      "description": "Request to swap duty between teachers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "assignmentId": { "type": "string" },
        "fromTeacherId": { "type": "string" },
        "toTeacherId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "requestedBy": { "type": "string" }
      },
      "required": ["id", "assignmentId", "fromTeacherId", "toTeacherId", "status"]
    },
    "Report": {
      "title": "Report",
      "description": "Incident report submitted by a teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "photoUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Submitted", "Under Review", "Action Taken", "Resolved"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "managementNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "teacherId", "teacherName", "category", "description", "status", "priority"]
    },
    "YearlyKpiRecord": {
      "title": "Yearly KPI Record",
      "description": "Yearly KPI assessments for teachers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "year": { "type": "number" },
        "averageMonthlyScore": { "type": "number" },
        "trendFactor": { "type": "number" },
        "finalScore": { "type": "number" },
        "rating": { "type": "string", "enum": ["A", "B", "C", "D", "E"] },
        "status": { "type": "string", "enum": ["Reviewed", "Pending", "Adjusted"] },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherId", "year", "averageMonthlyScore", "finalScore", "rating", "status"]
    }
  },
  "firestore": {
    "/reports": {
      "schema": "Report",
      "description": "Incident reports collection"
    },
    "/teachers": {
      "schema": "TeacherProfile",
      "description": "Main teacher directory"
    },
    "/performance_logs": {
      "schema": "PerformanceLog",
      "description": "Audit trail of performance adjustments"
    },
    "/summaries": {
      "schema": "MonthlySummary",
      "description": "Monthly performance aggregations"
    },
    "/warnings": {
      "schema": "Warning",
      "description": "Formal warning records"
    },
    "/notifications": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/duty_tasks": {
      "schema": "DutyTask",
      "description": "Duty templates"
    },
    "/duty_locations": {
      "schema": "DutyLocation",
      "description": "Duty locations"
    },
    "/duty_assignments": {
      "schema": "DutyAssignment",
      "description": "Active assignments"
    },
    "/leaves": {
      "schema": "LeaveRecord",
      "description": "Leave records"
    },
    "/duty_swaps": {
      "schema": "DutySwapRequest",
      "description": "Swap requests"
    },
    "/yearly_kpis": {
      "schema": "YearlyKpiRecord",
      "description": "Yearly KPI records"
    }
  }
}
