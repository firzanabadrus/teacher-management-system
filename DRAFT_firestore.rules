rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getTeacher(userId) {
      return get(/databases/$(database)/documents/teachers/$(userId)).data;
    }

    function isPrincipal() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/teachers/$(request.auth.uid)) &&
             getTeacher(request.auth.uid).role == 'principal';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- VALIDATION BLUEPRINTS ---

    function isValidTeacher(data) {
      return data.fullName is string && data.fullName.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['teacher', 'principal'] &&
             data.status in ['active', 'terminated'];
    }

    function isValidPerformanceLog(data) {
      return data.teacherId is string && data.teacherId.size() <= 128 &&
             data.amount is number &&
             data.reason is string && data.reason.size() <= 1000 &&
             data.category is string && data.category.size() <= 128 &&
             data.severity in ['Minor', 'Normal', 'Major', 'Critical'];
    }

    function isValidReport(data) {
      return data.teacherId is string && data.teacherId.size() <= 128 &&
             data.teacherName is string && data.teacherName.size() <= 200 &&
             data.category is string && data.category.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.status == 'Submitted' &&
             data.priority in ['Low', 'Medium', 'High'];
    }

    function isValidSwapRequest(data) {
      return data.assignmentId is string && data.assignmentId.size() <= 128 &&
             data.fromTeacherId is string && data.fromTeacherId.size() <= 128 &&
             data.toTeacherId is string && data.toTeacherId.size() <= 128 &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidLeave(data) {
      return data.teacherId is string && data.teacherId.size() <= 128 &&
             data.startDate is string && data.startDate.size() == 10 &&
             data.endDate is string && data.endDate.size() == 10 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.type in ['annual', 'medical', 'unpaid', 'maternity', 'marriage', 'compassionate', 'umrah', 'haji', 'birthday', 'halfday', 'sick', 'emergency', 'other'];
    }


    // --- SECURITY RULE MATCH BLOCKS ---

    // 1. Teachers Directory (Profile & Performance Score)
    match /teachers/{teacherId} {
      allow read: if isSignedIn() && (isPrincipal() || isOwner(teacherId));
      allow create: if isSignedIn() && isValidTeacher(request.resource.data);
      allow update: if isSignedIn() && (
        isPrincipal() ||
        (isOwner(teacherId) &&
         isValidTeacher(request.resource.data) &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.currentScore == resource.data.currentScore &&
         request.resource.data.yearlyKpi == resource.data.yearlyKpi &&
         request.resource.data.status == resource.data.status)
      );
      allow delete: if isPrincipal();
    }

    // 2. Performance Logs (Audit trail of merit & demerit points)
    match /performance_logs/{logId} {
      allow read: if isSignedIn() && (isPrincipal() || resource.data.teacherId == request.auth.uid);
      allow create: if isPrincipal() && isValidPerformanceLog(request.resource.data);
      allow update: if isPrincipal() && isValidPerformanceLog(request.resource.data);
      allow delete: if isPrincipal();
    }

    // 3. Summaries (Monthly Performance Aggregations)
    match /summaries/{summaryId} {
      allow read: if isSignedIn() && (isPrincipal() || resource.data.teacherId == request.auth.uid);
      allow write: if isPrincipal();
    }

    // 4. Warnings (Written disciplinary notifications)
    match /warnings/{warningId} {
      allow read: if isSignedIn() && (isPrincipal() || resource.data.teacherId == request.auth.uid);
      allow write: if isPrincipal();
    }

    // 5. Notifications (Direct messages, alerts, updates)
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (isPrincipal() || resource.data.userId == request.auth.uid || resource.data.userId == 'admin-id');
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isPrincipal() ||
        (resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']))
      );
      allow delete: if isSignedIn() && (isPrincipal() || resource.data.userId == request.auth.uid);
    }

    // 6. Reports (Incident Reporting System)
    match /reports/{reportId} {
      allow read: if isSignedIn() && (isPrincipal() || resource.data.teacherId == request.auth.uid);
      allow create: if isSignedIn() && isValidReport(request.resource.data);
      allow update: if isSignedIn() && (
        isPrincipal() ||
        (resource.data.teacherId == request.auth.uid &&
         resource.data.status == 'Submitted' &&
         request.resource.data.status == 'Submitted' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['description', 'photoUrl', 'lastUpdated']))
      );
      allow delete: if isPrincipal();
    }

    // 7. Duty Locations
    match /duty_locations/{locId} {
      allow read: if isSignedIn();
      allow write: if isPrincipal();
    }

    // 8. Duty Tasks (Recurring Duty Templates)
    match /duty_tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isPrincipal();
    }

    // 9. Duty Assignments (Shift allocations)
    match /duty_assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create: if isPrincipal();
      allow update: if isSignedIn() && (
        isPrincipal() ||
        (request.auth.uid in resource.data.teacherIds &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checklist', 'status', 'isReplacement']) &&
         request.resource.data.taskId == resource.data.taskId &&
         request.resource.data.date == resource.data.date &&
         request.resource.data.locationId == resource.data.locationId)
      );
      allow delete: if isPrincipal();
    }

    // 10. Leaves (Applications & approval histories)
    match /leaves/{leaveId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid && isValidLeave(request.resource.data);
      allow update: if isPrincipal();
      allow delete: if isPrincipal();
    }

    // 11. Duty Swaps (Colleague trades)
    match /duty_swaps/{swapId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromTeacherId == request.auth.uid && isValidSwapRequest(request.resource.data);
      allow update: if isSignedIn() && (
        isPrincipal() ||
        (request.auth.uid == resource.data.toTeacherId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
      );
      allow delete: if isPrincipal();
    }

    // 12. Yearly KPIs
    match /yearly_kpis/{kpiId} {
      allow read: if isSignedIn() && (isPrincipal() || resource.data.teacherId == request.auth.uid);
      allow write: if isPrincipal();
    }
  }
}
